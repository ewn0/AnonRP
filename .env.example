# ========================================
# AnonRP - Variables d'environnement
# ========================================
# Copie ce fichier en .env et remplis les valeurs
# Ne JAMAIS commit le fichier .env !

# --- Base de données PostgreSQL ---
# Neon : récupère la "Connection string" sur neon.tech
# Local : postgresql://user:password@localhost:5432/anonrp
DATABASE_URL="postgresql://user:password@host:5432/anonrp"

# --- Authentification NextAuth ---
# Génère un secret avec : openssl rand -base64 32
# Ou sur Windows PowerShell : [Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)}))
AUTH_SECRET="CHANGE_ME_LONG_RANDOM_STRING"
NEXTAUTH_URL="http://localhost:3000"

# --- Email (Resend - gratuit jusqu'à 3000 emails/mois) ---
# Crée un compte sur resend.com et récupère ta clé API
RESEND_API_KEY=""
EMAIL_FROM="noreply@anonrp.local"

# --- Stripe (Phase 4 - laisse vide pour l'instant) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Discord Bot (Phase 5 - laisse vide pour l'instant) ---
DISCORD_BOT_TOKEN=""
DISCORD_GUILD_ID=""
DISCORD_REPORTS_CHANNEL_ID=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# --- Admin initial (utilisé par le script de seed) ---
INITIAL_ADMIN_EMAIL="admin@anonrp.local"
INITIAL_ADMIN_USERNAME="admin"
INITIAL_ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
